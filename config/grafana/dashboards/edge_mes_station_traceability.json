    {
      "id": 7,
      "title": "三工站Cycle Time趋势",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "edge-mes-postgres"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "edge-mes-postgres"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(plc_end_time, $__interval),\n  station_id AS metric,\n  avg(cycle_time_ms) / 1000.0 AS value\nFROM cycle_event\nWHERE $__timeFilter(plc_end_time)\n  AND station_id IN (${station:sqlstring})\n  AND cycle_time_ms IS NOT NULL\nGROUP BY 1, station_id\nORDER BY 1;",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
