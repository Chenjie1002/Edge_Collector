          "datasource": {
            "type": "postgres",
            "uid": "edge-mes-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE WHEN count(*) = 0 THEN 0 ELSE round(100.0 * count(*) FILTER (WHERE result='OK') / count(*), 2) END AS value\nFROM cycle_event\nWHERE $__timeFilter(plc_end_time)\n  AND station_id = 'WS03';",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "percent",
          "decimals": 2,
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
