          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT code::text AS nok_code, count(*) AS count\nFROM cycle_event, unnest(nok_codes) AS code\nWHERE $__timeFilter(plc_end_time)\n  AND station_id IN (${station:sqlstring})\nGROUP BY code\nORDER BY count DESC, code\nLIMIT 20;",
          "refId": "A"
