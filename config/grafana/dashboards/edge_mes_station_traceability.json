          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT station_id, count(*) FILTER (WHERE result='OK') AS ok, count(*) FILTER (WHERE result='NOK') AS nok\nFROM cycle_event\nWHERE $__timeFilter(plc_end_time)\n  AND station_id IN (${station:sqlstring})\nGROUP BY station_id\nORDER BY station_id;",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "none"
