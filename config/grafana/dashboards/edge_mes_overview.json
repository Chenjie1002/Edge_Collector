          "rawSql": "WITH params AS (\n  SELECT\n    to_timestamp('${selected_date} ' || COALESCE(NULLIF('${start_time_custom}', ''), '${start_time}'), 'YYYY-MM-DD HH24:MI') AS t_from,\n    CASE\n      WHEN COALESCE(NULLIF('${end_time_custom}', ''), '${end_time}') = '24:00'\n      THEN to_timestamp('${selected_date} 00:00', 'YYYY-MM-DD HH24:MI') + interval '1 day'\n      ELSE to_timestamp('${selected_date} ' || COALESCE(NULLIF('${end_time_custom}', ''), '${end_time}'), 'YYYY-MM-DD HH24:MI')\n    END AS t_to\n)\nSELECT p.ts AS time, round(p.cycle_time_ms::numeric / 1000.0, 2) AS \"Cycle Time (s)\" FROM production_snapshot p CROSS JOIN params WHERE p.machine_id = 'LINE_01' AND p.ts >= params.t_from AND p.ts <= params.t_to AND p.running = TRUE ORDER BY p.ts;",
