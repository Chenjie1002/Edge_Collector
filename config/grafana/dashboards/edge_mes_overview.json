      "targets": [
        {
          "datasource": {
            "uid": "edge-mes-postgres"
          },
          "format": "time_series",
          "rawSql": "WITH params AS (\n  SELECT\n    to_timestamp('${selected_date} ' || COALESCE(NULLIF('${start_time_custom}', ''), '${start_time}'), 'YYYY-MM-DD HH24:MI') AS t_from,\n    CASE\n      WHEN COALESCE(NULLIF('${end_time_custom}', ''), '${end_time}') = '24:00'\n      THEN to_timestamp('${selected_date} 00:00', 'YYYY-MM-DD HH24:MI') + interval '1 day'\n      ELSE to_timestamp('${selected_date} ' || COALESCE(NULLIF('${end_time_custom}', ''), '${end_time}'), 'YYYY-MM-DD HH24:MI')\n    END AS t_to\n)\n, ticks AS (\n  SELECT generate_series(params.t_from, params.t_to, interval '30 seconds') AS time, params.t_from, params.t_to\n  FROM params\n), snap AS (\n  SELECT\n    p.ts,\n    p.good_count,\n    lag(p.good_count) OVER (ORDER BY p.ts) AS prev_good\n  FROM production_snapshot p CROSS JOIN params\n  WHERE p.machine_id = 'LINE_01'\n    AND p.ts >= params.t_from\n    AND p.ts <= params.t_to\n), good_events AS (\n  SELECT\n    ts AS time,\n    greatest(good_count - COALESCE(prev_good, good_count), 0)::int AS good_delta\n  FROM snap\n), actual_at_ticks AS (\n  SELECT\n    ticks.time,\n    COALESCE((\n      SELECT sum(good_delta)\n      FROM good_events\n      WHERE good_events.time <= ticks.time\n    ), 0)::int AS actual_output,\n    floor(extract(epoch FROM (ticks.time - ticks.t_from)) / 30.0)::int AS theoretical_output\n  FROM ticks\n)\nSELECT\n  time,\n  actual_output AS \"实际产量\",\n  theoretical_output AS \"理论产量\"\nFROM actual_at_ticks\nORDER BY time;",
          "refId": "A",
          "rawQuery": true,
          "editorMode": "code"
        }
      ],
